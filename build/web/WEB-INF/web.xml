    </servlet-mapping>
    <!-- Session Timeout -->
    <servlet-mapping>
        <servlet-name>CandidateForgotPasswordServlet</servlet-name>
        <url-pattern>/CandidateForgotPasswordServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CandidateVerifyOTPServlet</servlet-name>
        <url-pattern>/CandidateVerifyOTPServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CandidateResendOTPServlet</servlet-name>
        <url-pattern>/CandidateResendOTPServlet</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
    <!-- Welcome File -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>
