<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd">
    <!-- Database connection parameters -->
    <context-param>
        <param-name>dbURL</param-name>
        <param-value>jdbc:mysql://localhost:3306/registrationdb</param-value>
    </context-param>
    <context-param>
        <param-name>dbUser</param-name>
        <param-value>root</param-value>
    </context-param>
    <context-param>
        <param-name>dbPassword</param-name>
        <param-value>root</param-value>
    </context-param>
    <!-- Filters -->
    <filter>
        <filter-name>CandidateAuthFilter</filter-name>
        <filter-class>com.voting.CandidateAuthFilter</filter-class>
    </filter>
    <filter>
        <filter-name>VoterAuthFilter</filter-name>
        <filter-class>com.voting.VoterAuthFilter</filter-class>
    </filter>
    <filter>
        <filter-name>AdminAuthFilter</filter-name>
        <filter-class>com.voting.AdminAuthFilter</filter-class>
    </filter>
    <!-- Filter Mappings - FIXED -->
    <filter-mapping>
        <filter-name>CandidateAuthFilter</filter-name>
        <url-pattern>/candidate-dashboard.jsp</url-pattern>
        <url-pattern>/candidate-profile.jsp</url-pattern>
        <!-- Add other candidate-protected pages here -->
    </filter-mapping>
    <filter-mapping>
        <filter-name>VoterAuthFilter</filter-name>
        <url-pattern>/user-dashboard.jsp</url-pattern>
        <!-- Add other voter-protected pages here -->
    </filter-mapping>
    <filter-mapping>
        <filter-name>AdminAuthFilter</filter-name>
        <url-pattern>/admin-dashboard.jsp</url-pattern>
        <url-pattern>/manage-candidates.jsp</url-pattern>
        <url-pattern>/system-settings.jsp</url-pattern>
        <!-- Add other admin-protected pages here -->
    </filter-mapping>
    <!-- Servlets -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.voting.RegisterServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.voting.LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>VoteServlet</servlet-name>
        <servlet-class>com.voting.VoteServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.voting.DashboardServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.voting.LogoutServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AdminLoginServlet</servlet-name>
        <servlet-class>com.voting.AdminLoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UpdateVoterServlet</servlet-name>
        <servlet-class>com.voting.UpdateVoterServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>VoteSyncServlet</servlet-name>
        <servlet-class>com.voting.VoteSyncServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>VoteDeleteServlet</servlet-name>
        <servlet-class>com.voting.VoteDeleteServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AddAdminServlet</servlet-name>
        <servlet-class>com.voting.AddAdminServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DeleteAdminServlet</servlet-name>
        <servlet-class>com.voting.DeleteAdminServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AdminLogoutServlet</servlet-name>
        <servlet-class>com.voting.AdminLogoutServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>VoterLogoutServlet</servlet-name>
        <servlet-class>com.voting.VoterLogoutServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ForgotPasswordServlet</servlet-name>
        <servlet-class>com.voting.ForgotPasswordServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>VerifyOTPServlet</servlet-name>
